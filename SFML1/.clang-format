BasedOnStyle: LLVM
Language: Cpp
Standard: c++17

# Отступы
IndentWidth: 4
TabWidth: 4
UseTab: Never

# Длина строки
ColumnLimit: 100

# Скобки — { на той же строке
BreakBeforeBraces: Attach
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
AllowShortFunctionsOnASingleLine: false

# Пространства имён
NamespaceIndentation: All
FixNamespaceComments: true

# Выравнивание по столбикам не включаем
AlignConsecutiveDeclarations: None
AlignConsecutiveAssignments: None
AlignConsecutiveMacros: None

# Пробелы
SpaceBeforeParens: ControlStatements
SpaceBeforeRangeBasedForLoopColon: true
SpaceAfterCStyleCast: true

# Указатели и ссылки прилеплены к типу
DerivePointerAlignment: false
PointerAlignment: Left
ReferenceAlignment: Left

# include-ы
SortIncludes: true
IncludeBlocks: Regroup
IncludeCategories:
  # 1) SFML-хедеры: <SFML/Graphics.hpp>, <SFML/System.hpp>, ...
  - Regex: '^<SFML/.*>'
    Priority: 1

  # 2) Стандартная библиотека: <vector>, <string>, <memory>...
  - Regex: '^<.*>'
    Priority: 0

  # 3) third_party: "third_party/json_silent.hpp" и т.п.
  - Regex: '^"third_party/.*"'
    Priority: 2

  # 4) Мои хедеры движка/игр: "core/...", "entities/...", "utils/..." и т.п.
  - Regex: '^"(core|entities|graphics|utils)/.*"'
    Priority: 3

  # 5) Всё остальное в кавычках — в самый конец, на всякий случай
  - Regex: '^".*"'
    Priority: 4

# Комментарии — не трогаем текст, чтобы не ломать смысл
ReflowComments: false